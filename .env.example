# Stellavault - Environment Variables
# Copy this file to .env and fill in your values

# Required: Path to your Obsidian vault
OBSIDIAN_PATH=/path/to/your/obsidian/vault

# Optional: Custom database path (default: ~/.stellavault/index.db)
# STELLAVAULT_DB_PATH=/custom/path/to/index.db

# Optional: Notion integration (for sync feature)
# NOTION_TOKEN=your_notion_integration_token
# NOTION_DATABASE_ID=your_database_id
