# 환경변수 (API 키 포함)
.env

# 백업 파일 (만료 토큰/시크릿 포함 가능성)
*.bak
*.bak.*

# 동기화 상태 파일
.sync-state.json
.upload-state.json

# Autopilot runtime state (per-machine, not portable)
.autopilot-state.json

# Codex session pointer (per-machine)
.context/

# 의존성
node_modules/

# 로그
logs/

# 빌드 출력
dist/

# 자동 생성 배치 파일
run-sync.bat

# Stellavault 설정 (사용자별)
.stellavault.json

# Stellavault 데이터베이스
*.db
*.db-journal

# TypeScript 캐시
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
# PowerShell module-analysis cache (leaks into cwd when LOCALAPPDATA unset)
Microsoft/

# IDE
.idea/
.vscode/
*.swp

# bkit / claude internal
.bkit/
.claude/

# Auto-memory (per-user)
memory/

# Test screenshots
packages/graph/*.png

# MCP / Playwright logs
.mcp.json
.playwright-mcp/

# Legacy config
.ekh.json

# Stray files (not part of project)
unnamed*.png
Autonomous_Knowledge_Foundry.pdf
tmp-pw/
packages/desktop/out/

# Stray vault output when ingest/tests run from a package dir (compiled wiki + raw notes)
packages/*/_wiki/
packages/*/raw/

# npm audit / dependency scratch dumps (ephemeral — never commit)
audit.json
audit_full.json
audit_temp.json
audit-tmp.json
lstree.json
