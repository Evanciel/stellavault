    "b4a": "^1.8.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "hyperswarm": "^4.17.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "officeparser": "^6.0.7",
