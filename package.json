{
  "name": "stellavault",
  "version": "0.4.3",
  "description": "Self-compiling knowledge MCP server — ingest anything, auto-organize into Zettelkasten wiki, search with AI, and let Claude access your entire knowledge base.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Evanciel/stellavault"
  },
  "homepage": "https://github.com/Evanciel/stellavault",
  "bugs": "https://github.com/Evanciel/stellavault/issues",
  "keywords": ["obsidian", "knowledge-graph", "3d-visualization", "vector-search", "mcp", "fsrs", "ai"],
  "license": "MIT",
  "author": "Evan",
  "type": "module",
  "workspaces": [
    "packages/sync",
    "packages/core",
    "packages/cli",
    "packages/graph"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "sync": "npm run sync --workspace=@stellavault/sync",
    "dev:core": "npm run dev --workspace=@stellavault/core"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
